      "args": [
        "build",
        "../Nuri.Duxel/Nuri.Duxel.PreviewHost/Nuri.Duxel.PreviewHost.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
